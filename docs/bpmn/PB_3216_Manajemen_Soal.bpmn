<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ProsesManajemenSoal" targetNamespace="http://www.bizagi.com/gamifikasi/bpmn">
  <bpmn:collaboration>
    <bpmn:participant id="Pool_ProsesManajemenSoal" name="Mengelola Soal" processRef="ProsesManajemenSoal"/>
  </bpmn:collaboration>
  <bpmn:process id="ProsesManajemenSoal" isExecutable="false">
    <bpmn:laneSet>
      <bpmn:lane id="Lane_ProsesManajemenSoal" name="Admin (Guru)">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_access</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_login</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_menu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_pre0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_pre1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_cari1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_cari2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_add1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_add2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_add3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_edit1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_edit2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_edit3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_del1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G_del</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_del2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_del3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_show</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Mulai">
      <bpmn:outgoing>F_Start_T_access</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_access" name="Mengakses website">
      <bpmn:incoming>F_Start_T_access</bpmn:incoming>
      <bpmn:outgoing>F_T_access_T_login</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_login" name="Login">
      <bpmn:incoming>F_T_access_T_login</bpmn:incoming>
      <bpmn:outgoing>F_T_login_T_menu</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_menu" name="Klik menu manajemen soal">
      <bpmn:incoming>F_T_login_T_menu</bpmn:incoming>
      <bpmn:outgoing>F_T_menu_T_pre0</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_pre0" name="Memilih tema pembelajaran">
      <bpmn:incoming>F_T_menu_T_pre0</bpmn:incoming>
      <bpmn:outgoing>F_T_pre0_T_pre1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_pre1" name="Memilih tanggal belajar">
      <bpmn:incoming>F_T_pre0_T_pre1</bpmn:incoming>
      <bpmn:outgoing>F_T_pre1_G_split</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G_split" gatewayDirection="Diverging">
      <bpmn:incoming>F_T_pre1_G_split</bpmn:incoming>
      <bpmn:outgoing>F_split_cari</bpmn:outgoing>
      <bpmn:outgoing>F_split_add</bpmn:outgoing>
      <bpmn:outgoing>F_split_edit</bpmn:outgoing>
      <bpmn:outgoing>F_split_del</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_cari1" name="Mengklik kolom cari soal">
      <bpmn:incoming>F_split_cari</bpmn:incoming>
      <bpmn:outgoing>F_cari1_cari2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_cari2" name="Memasukkan kriteria pencarian">
      <bpmn:incoming>F_cari1_cari2</bpmn:incoming>
      <bpmn:outgoing>F_cari2_merge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_add1" name="Memilih tombol tambah soal">
      <bpmn:incoming>F_split_add</bpmn:incoming>
      <bpmn:outgoing>F_add1_add2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_add2" name="Mengisi data tambah soal">
      <bpmn:incoming>F_add1_add2</bpmn:incoming>
      <bpmn:outgoing>F_add2_add3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_add3" name="Memilih tombol simpan data">
      <bpmn:incoming>F_add2_add3</bpmn:incoming>
      <bpmn:outgoing>F_add3_merge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_edit1" name="Memilih tombol edit">
      <bpmn:incoming>F_split_edit</bpmn:incoming>
      <bpmn:outgoing>F_edit1_edit2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_edit2" name="Memperbarui data soal">
      <bpmn:incoming>F_edit1_edit2</bpmn:incoming>
      <bpmn:outgoing>F_edit2_edit3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_edit3" name="Pilih tombol simpan">
      <bpmn:incoming>F_edit2_edit3</bpmn:incoming>
      <bpmn:outgoing>F_edit3_merge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_del1" name="Memilih tombol delete">
      <bpmn:incoming>F_split_del</bpmn:incoming>
      <bpmn:outgoing>F_del1_gdel</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G_del" gatewayDirection="Diverging">
      <bpmn:incoming>F_del1_gdel</bpmn:incoming>
      <bpmn:outgoing>F_gdel_hapus</bpmn:outgoing>
      <bpmn:outgoing>F_gdel_batal</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_del2" name="Pilih tombol hapus">
      <bpmn:incoming>F_gdel_hapus</bpmn:incoming>
      <bpmn:outgoing>F_del2_merge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_del3" name="Pilih tombol batal">
      <bpmn:incoming>F_gdel_batal</bpmn:incoming>
      <bpmn:outgoing>F_del3_merge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G_merge" gatewayDirection="Converging">
      <bpmn:incoming>F_cari2_merge</bpmn:incoming>
      <bpmn:incoming>F_add3_merge</bpmn:incoming>
      <bpmn:incoming>F_edit3_merge</bpmn:incoming>
      <bpmn:incoming>F_del2_merge</bpmn:incoming>
      <bpmn:incoming>F_del3_merge</bpmn:incoming>
      <bpmn:outgoing>F_merge_show</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_show" name="Menampilkan data soal">
      <bpmn:incoming>F_merge_show</bpmn:incoming>
      <bpmn:outgoing>F_show_end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End" name="Selesai">
      <bpmn:incoming>F_show_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_T_access" sourceRef="Start" targetRef="T_access"/>
    <bpmn:sequenceFlow id="F_T_access_T_login" sourceRef="T_access" targetRef="T_login"/>
    <bpmn:sequenceFlow id="F_T_login_T_menu" sourceRef="T_login" targetRef="T_menu"/>
    <bpmn:sequenceFlow id="F_T_menu_T_pre0" sourceRef="T_menu" targetRef="T_pre0"/>
    <bpmn:sequenceFlow id="F_T_pre0_T_pre1" sourceRef="T_pre0" targetRef="T_pre1"/>
    <bpmn:sequenceFlow id="F_T_pre1_G_split" sourceRef="T_pre1" targetRef="G_split"/>
    <bpmn:sequenceFlow id="F_split_cari" sourceRef="G_split" targetRef="T_cari1" name="Cari"/>
    <bpmn:sequenceFlow id="F_cari1_cari2" sourceRef="T_cari1" targetRef="T_cari2"/>
    <bpmn:sequenceFlow id="F_cari2_merge" sourceRef="T_cari2" targetRef="G_merge"/>
    <bpmn:sequenceFlow id="F_split_add" sourceRef="G_split" targetRef="T_add1" name="Tambah"/>
    <bpmn:sequenceFlow id="F_add1_add2" sourceRef="T_add1" targetRef="T_add2"/>
    <bpmn:sequenceFlow id="F_add2_add3" sourceRef="T_add2" targetRef="T_add3"/>
    <bpmn:sequenceFlow id="F_add3_merge" sourceRef="T_add3" targetRef="G_merge"/>
    <bpmn:sequenceFlow id="F_split_edit" sourceRef="G_split" targetRef="T_edit1" name="Edit"/>
    <bpmn:sequenceFlow id="F_edit1_edit2" sourceRef="T_edit1" targetRef="T_edit2"/>
    <bpmn:sequenceFlow id="F_edit2_edit3" sourceRef="T_edit2" targetRef="T_edit3"/>
    <bpmn:sequenceFlow id="F_edit3_merge" sourceRef="T_edit3" targetRef="G_merge"/>
    <bpmn:sequenceFlow id="F_split_del" sourceRef="G_split" targetRef="T_del1" name="Hapus"/>
    <bpmn:sequenceFlow id="F_del1_gdel" sourceRef="T_del1" targetRef="G_del"/>
    <bpmn:sequenceFlow id="F_gdel_hapus" sourceRef="G_del" targetRef="T_del2" name="Ya"/>
    <bpmn:sequenceFlow id="F_gdel_batal" sourceRef="G_del" targetRef="T_del3" name="Tidak"/>
    <bpmn:sequenceFlow id="F_del2_merge" sourceRef="T_del2" targetRef="G_merge"/>
    <bpmn:sequenceFlow id="F_del3_merge" sourceRef="T_del3" targetRef="G_merge"/>
    <bpmn:sequenceFlow id="F_merge_show" sourceRef="G_merge" targetRef="T_show"/>
    <bpmn:sequenceFlow id="F_show_end" sourceRef="T_show" targetRef="End"/>
  </bpmn:process>
